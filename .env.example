# ============================================================
# KGPlatform Environment Configuration
# ============================================================
# Copy to .env and adjust for your deployment.
# All variables have sane defaults — you only need to change
# passwords and model names for production use.

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Fuseki ---
FUSEKI_ADMIN_PASSWORD=admin
FUSEKI_DATASET=kgbuilder

# --- Qdrant ---
QDRANT_COLLECTION=kgbuilder

# --- Ollama Models ---
# Each service can use a different model.
# Models are pulled automatically on first `docker compose up`.
KGBUILDER_MODEL=qwen3:8b
GRAPHQA_MODEL=qwen3:8b
ONTOLOGY_MODEL=qwen3:8b
EMBED_MODEL=qwen3-embedding

# --- Logging ---
LOG_LEVEL=INFO
